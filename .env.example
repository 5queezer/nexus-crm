# Database adapter: "prisma" (PostgreSQL/SQLite) or "firestore"
DB_PROVIDER="prisma"

# Required for auth (always uses Prisma/PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/job_tracker"

BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="https://jobs.vasudev.xyz"
GOOGLE_CLIENT_ID="your-google-client-id-from-console.cloud.google.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret-from-console.cloud.google.com"
ALLOWED_EMAIL="christian.pojoni@gmail.com"

# File storage: set GCS_BUCKET for Cloud Storage, omit for local filesystem
# GCS_BUCKET="your-bucket-name"
